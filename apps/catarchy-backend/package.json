{
  "name": "catarchy-backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/server.ts",
    "dev:cf": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "bun --version && tsc --emitDeclarationOnly && bun build src/index.ts --outdir ./dist --target bun --external cloudflare:workers",
    "build:types": "tsc -b .",
    "start": "bun run dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate && bun run src/infra/db/fix-migration.ts",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote",
    "db:seed:local": "wrangler d1 execute catarchy-db --local --file src/infra/db/seed.sql",
    "db:seed:prod": "wrangler d1 execute catarchy-db --remote --file src/infra/db/seed.sql",
    "db:reset": "bun run scripts/db-reset.ts",
    "db:update-config": "bun run scripts/db-update-config.ts",
    "db:delete-user": "bun run scripts/db-delete-user.ts",
    "db:seed-test-users": "bun run scripts/db-seed-test-users.ts",
    "db:delete-test-users": "bun run scripts/db-delete-test-users.ts",
    "localflare": "localflare"
  },
  "dependencies": {
    "@ai-sdk/alibaba": "1.0.25",
    "@ai-sdk/anthropic": "3.0.81",
    "@catarchy/shared": "workspace:*",
    "@elysiajs/cors": "1.4.2",
    "@elysiajs/eden": "1.4.9",
    "@elysiajs/jwt": "1.4.2",
    "@elysiajs/openapi": "1.4.15",
    "ai": "6.0.193",
    "ai-gateway-provider": "3.1.3",
    "bcryptjs": "3.0.3",
    "drizzle-orm": "0.45.2",
    "drizzle-typebox": "0.3.3",
    "elysia": "1.4.28",
    "ms": "2.1.3",
    "resend": "6.12.4",
    "uuidv7": "1.2.1",
    "viem": "2.51.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260529.1",
    "@types/bun": "1.3.14",
    "@types/ms": "2.1.0",
    "drizzle-kit": "0.31.10",
    "localflare": "0.5.0",
    "typescript": "6.0.3",
    "wrangler": "4.95.0"
  }
}
