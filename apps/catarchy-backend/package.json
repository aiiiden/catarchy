{
  "name": "catarchy-backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/server.ts",
    "dev:cf": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --emitDeclarationOnly && bun build src/index.ts --outdir ./dist --target bun --external cloudflare:workers",
    "start": "bun run dist/index.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote",
    "db:seed:local": "wrangler d1 execute catarchy-db --local --file src/infra/db/seed.sql",
    "db:seed:prod": "wrangler d1 execute catarchy-db --remote --file src/infra/db/seed.sql"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@elysiajs/cors": "latest",
    "@elysiajs/eden": "latest",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/openapi": "latest",
    "ai": "^6.0.116",
    "ai-gateway-provider": "^3.1.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "drizzle-typebox": "^0.3.3",
    "elysia": "latest",
    "resend": "^6.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9",
    "prettier": "latest",
    "typescript": "latest",
    "wrangler": "^4.69.0"
  }
}
